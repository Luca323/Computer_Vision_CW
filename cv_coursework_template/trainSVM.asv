function model = trainSVM(X, y, kernel)
    classes = categories(y);
    numClasses = numel(classes);

    model.BinaryModels = cell(numClasses, 1);
    model.ClassNames = classes;

    BC = 1;

    for i = 1:numClasses
        current = classes{i};
        binaryLabels = (y == current);
        model.BinaryModels{i} = fitcsvm(X, binaryLabels, 'KernelFunction', kernel, ...
            '','BoxConstraint',BC);
    end

end